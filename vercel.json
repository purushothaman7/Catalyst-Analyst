{
    "version": 2,
    "builds": [
      {
        "src": "GUI.py",
        "use": "@vercel/python",
         "config": {
            "installCommand": "pip install --upgrade pip setuptools && pip install -r requirements.txt"
          }
      }
    ],
    
    "routes": [
      {
        "src": "/(.*)",
        "dest": "GUI.py"
      }
    ],
    "env": {
      "FLASK_ENV": "production"
    }
  }
  