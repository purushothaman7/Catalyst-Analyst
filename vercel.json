{
    "version": 2,
    "builds": [
      {
        "src": "GUI.py",
        "use": "@vercel/python"
      },
      {
        "src": "templates/**",
        "use": "@vercel/static"
      },
      {
        "src": "data.csv",
        "use": "@vercel/static"
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "GUI.py"
      }
    ]
  }
  